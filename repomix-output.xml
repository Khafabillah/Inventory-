    <script>
        // Fungsi untuk Modal Edit Kategori
        window.openEditCategoryModal = function(button) {
            try {
                const id = button.getAttribute('data-id');
                const name = button.getAttribute('data-name');
                const code = button.getAttribute('data-code');

                const form = document.getElementById('formEditKategori');
                if (form) form.action = `/master-data/kategori/${id}`;

                document.getElementById('edit_category_name').value = name;
                document.getElementById('edit_category_code').value = code;

                window.toggleModal('modalEditKategori');
            } catch (error) {
                console.error("Gagal membuka modal edit kategori:", error);
            }
        };

        // Fungsi untuk Modal Hapus Kategori
        window.openDeleteCategoryModal = function(button) {
            try {
                const id = button.getAttribute('data-id');
                const name = button.getAttribute('data-name');

                const form = document.getElementById('formHapusKategori');
                if (form) form.action = `/master-data/kategori/${id}`;

                document.getElementById('delete_category_name').innerText = name;

                window.toggleModal('modalHapusKategori');
            } catch (error) {
                console.error("Gagal membuka modal hapus kategori:", error);
            }
        };
    </script>
@endsection
